{
  "name": "siegeiq-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SiegeIQ — Rainbow Six Siege improvement coach. Overwolf desktop app, API service, marketing site, shared packages.",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:web": "npm run dev -w @siegeiq/web",
    "dev:api": "npm run dev -w @siegeiq/api",
    "dev:desktop": "npm run dev -w @siegeiq/desktop",
    "build": "npm run build --workspaces --if-present",
    "build:desktop": "npm run build -w @siegeiq/desktop",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "ioredis": "^5.11.1",
    "zod": "^3.24.1"
  },
  "overrides": { "ioredis": "$ioredis" }
}
