{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["vite/client", "@overwolf/types"],
    "paths": {
      "@/*": ["./src/*"],
      "@siegeiq/shared": ["../../packages/shared/src/index.ts"],
