{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:4000/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/maps/[slug]",
      "regex": "^/maps/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/maps/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/operators/[slug]",
      "regex": "^/operators/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/operators/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/profile/[platform]/[username]",
      "regex": "^/profile/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPplatform": "nxtPplatform",
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/profile/(?<nxtPplatform>[^/]+?)/(?<nxtPusername>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/icon.svg",
      "regex": "^/icon\\.svg(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.svg(?:/)?$"
    },
    {
      "page": "/live",
      "regex": "^/live(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/live(?:/)?$"
    },
    {
      "page": "/maps",
      "regex": "^/maps(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/maps(?:/)?$"
    },
    {
      "page": "/operators",
      "regex": "^/operators(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/operators(?:/)?$"
    },
    {
      "page": "/weapons",
      "regex": "^/weapons(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/weapons(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}