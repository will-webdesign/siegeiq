# ── SiegeIQ environment ────────────────────────────────────────────────
# Copy to .env (dev) or set in your deployment. The app boots with ZERO
# configuration in demo mode.

# Demo mode: serves deterministic sample data so the full UI works without
# credentials, a database, or Redis. Set to "false" for real data.
DEMO_MODE=true

# Provider failover order (comma separated): ubisoft, r6data, demo
PROVIDER_ORDER=ubisoft,r6data,demo

# ── Ubisoft service account (primary provider) ─────────────────────────
# Create a DEDICATED burner account at account.ubisoft.com (2FA disabled).
# Never use a personal account. End users never see or need this.
UBI_EMAIL=
UBI_PASSWORD=

# ── R6Data community API (fallback provider) ───────────────────────────
# Optional. Key from https://r6data.com/dashboard (server-side only).
R6DATA_API_KEY=

# ── Infrastructure ─────────────────────────────────────────────────────
# Optional in demo mode; required for real data + history recording.
DATABASE_URL=postgresql://siegeiq:siegeiq@localhost:5432/siegeiq
REDIS_URL=redis://localhost:6379

# ── Live match (worker) ────────────────────────────────────────────────
LIVE_WS_PORT=8787
# Secret used to sign companion pairing tokens. Generate: openssl rand -hex 32
PAIRING_SECRET=change-me

# ── Admin ──────────────────────────────────────────────────────────────
# Bearer token for /admin and /api/admin/*. Generate: openssl rand -hex 24
ADMIN_TOKEN=change-me

# ── Public ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
